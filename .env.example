# ==================== FlowLite Docker Environment ====================
# Copy this file to .env.docker and fill in the values.
# NEVER commit .env.docker to version control!

# ==================== DATABASE ====================
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=flowlite
MYSQL_USER=flowlite
MYSQL_PASSWORD=change-me-db-password

# ==================== JWT ====================
JWT_SECRET=change-me-to-a-secure-random-string-at-least-256-bits
JWT_EXPIRATION=86400000

# ==================== CORS ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ==================== COOKIE ====================
COOKIE_SECURE=false

# ==================== SPRING ====================
SPRING_PROFILES_ACTIVE=docker
JPA_DDL_AUTO=update

# ==================== EMAIL (Optional) ====================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# FlowLite Environment Configuration
# ====================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# Database Configuration
# ----------------------
# For H2 (default - development)
DATABASE_URL=jdbc:h2:mem:flowlite
DATABASE_USERNAME=sa
DATABASE_PASSWORD=

# For MySQL (production)
# DATABASE_URL=jdbc:mysql://localhost:3306/flowlite
# DATABASE_USERNAME=flowlite_user
# DATABASE_PASSWORD=your_secure_password

# JWT Configuration
# -----------------
# Minimum 256-bit (32 bytes) secret key for HS256
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRATION=86400000

# Email Configuration (SMTP)
# --------------------------
# Leave empty to disable email notifications
# For Gmail, use App Password (not regular password)
# See SETUP.md for instructions on generating App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Application URLs
# ----------------
# Frontend URL for links in emails
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FLOWLITE_APP_URL=http://localhost:3000
